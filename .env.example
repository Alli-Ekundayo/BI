# .env.example

# LLM
GOOGLE_API_KEY=AIzaSyDqC7nKVVqlvNOf7_Gtt6ymt26Dx1pwosQ

# Security
SECRET_KEY=yourname
# App
ENVIRONMENT=production

# Hosted datasources — one env var per named datasource.
# The frontend sends a datasource_id (e.g. "prod_db"); the backend resolves it here.
# SSL is enforced automatically by the connectors — no extra param needed.
DB_URL_PROD_DB=postgresql://ergo:alliekundayo@localhost:5432/transaction_snapshot
DB_URL_ANALYTICS_DB=postgresql://user:password@your-analytics-host.com:5432/analytics
DB_URL_EVENTS_DB=mongodb+srv://user:password@cluster.mongodb.net/events
